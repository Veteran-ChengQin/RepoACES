+  const cleanedText = simpleMarkdownText(result + text.slice(lastIndex));
+
+  return Array.from(preservedMarkdownImages.entries()).reduce(
+    (text, [token, rawMarkdown]) => text.replaceAll(token, rawMarkdown),
+    cleanedText
+  );
 };
