+    const token = `__FASTGPT_MARKDOWN_IMAGE_${index}_PLACEHOLDER__`;
+    preservedMarkdownImages.set(token, image.fullMatch);
+    return token;
   };
+
+  const uploadResults = controller
+    ? await batchRun(
+        images,
